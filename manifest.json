{
  "manifest_version": 2,
  "name": "Gmail Navbar Shortcuts",
  "version": "1.2.5",
  "description": "Adds icon shortcuts to Gmail's left navbar with configurable URLs and titles.",
  "author": "s7dhansh",
  "homepage_url": "https://github.com/appkari/gmail-navbar-shortcuts",

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "run_at": "document_start",
      "js": ["vars.js", "svgs.js", "content.js"],
      "css": ["options.css"]
    }
  ],

  "browser_action": {
    "default_title": "Gmail Navbar Shortcuts - Options",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "permissions": ["storage"],

  "browser_specific_settings": {
    "gecko": {
      "id": "gmail-navbar-shortcuts@s7dhansh",
      "strict_min_version": "109.0"
    }
  }
}
